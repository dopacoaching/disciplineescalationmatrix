PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/discipline-escalation-matrix?appName=Cluster0
JWT_SECRET=replace_with_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12
# Comma-separated: email:password — used only by `npm run seed`, safe to remove after first deploy
ADMIN_CREDENTIALS=admin@dopacoaching.com:StrongPassword123!
# Only needed for local dev cross-origin. Not required on Vercel (same-domain deployment).
# CLIENT_URL=https://your-app.vercel.app
